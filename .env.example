# Copy to .env and fill in all values before starting the app.

# PostgreSQL connection string (local on same server)
DATABASE_URL=postgresql://autoscore:YOURPASSWORD@localhost:5432/autoscore

# GitHub webhook secret — must match the secret set in GitHub → Settings → Webhooks
# Generate:  openssl rand -hex 32
GITHUB_SECRET=

# S3 backup bucket name
S3_BUCKET_NAME=your-s3-bucket-name
S3_PREFIX=backups/db
BACKUP_DIR=/home/ubuntu/backups

# AWS region (if not using IAM instance profile, also set ACCESS_KEY_ID / SECRET_ACCESS_KEY)
AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Secret for the backup health-check endpoint (GET /api/health/backup?secret=...)
# Generate:  openssl rand -hex 32
HEALTH_SECRET=

# App port (Nginx proxies here; keep 3000 unless you change nginx.conf)
PORT=3000
